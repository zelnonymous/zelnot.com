---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Technology Consulting">
  <section class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white section-padding">
    <div class="container-tight">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Technology Solutions for 
          <span class="text-sky-400">Growing Businesses</span>
        </h1>
        <p class="text-xl text-slate-300 mb-8 leading-relaxed">
          From startup to enterprise, I help organizations build better software, 
          streamline operations, and accelerate delivery through expert consulting services.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact#consultation" class="btn-primary text-lg px-8 py-4">
            Request a Consultation
          </a>
          <a href="/services" class="btn-ghost text-lg px-8 py-4">
            Explore Services
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-slate-50">
    <div class="container-tight">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">
          Core Services
        </h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          Comprehensive technology consulting to help your business succeed.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
          <div class="w-14 h-14 bg-sky-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">Custom Software Development</h3>
          <p class="text-slate-600 mb-6">
            Bespoke applications built to your exact specifications. From web platforms to internal tools, 
            I deliver clean, maintainable code that scales with your business.
          </p>
          <a href="/services#development" class="text-sky-600 font-semibold hover:text-sky-700 inline-flex items-center gap-2">
            Learn more
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <div class="bg-white p-8 rounded-xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
          <div class="w-14 h-14 bg-sky-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">Software Integration</h3>
          <p class="text-slate-600 mb-6">
            Connect your systems and data. I architect integration solutions that unify your 
            technology stack, eliminating silos and enabling seamless information flow.
          </p>
          <a href="/services#integration" class="text-sky-600 font-semibold hover:text-sky-700 inline-flex items-center gap-2">
            Learn more
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <div class="bg-white p-8 rounded-xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
          <div class="w-14 h-14 bg-sky-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">DevOps & CI/CD</h3>
          <p class="text-slate-600 mb-6">
            Automate your pipeline from code to production. I implement robust CI/CD workflows, 
            configuration management, and monitoring that keeps your systems running smoothly.
          </p>
          <a href="/services#devops" class="text-sky-600 font-semibold hover:text-sky-700 inline-flex items-center gap-2">
            Learn more
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-tight">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6">
            Industry Experience
          </h2>
          <p class="text-lg text-slate-600 mb-8">
            I've had the privilege of working across diverse sectors, bringing deep technical 
            expertise and a understanding of unique industry challenges.
          </p>
          <div class="grid grid-cols-2 gap-4">
            {[
              'Healthcare',
              'Manufacturing',
              'Finance',
              'Insurance',
              'Retail',
              'Education'
            ].map(industry => (
              <div class="flex items-center gap-3 text-slate-700">
                <svg class="w-5 h-5 text-sky-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                {industry}
              </div>
            ))}
          </div>
        </div>
        <div class="bg-gradient-to-br from-slate-100 to-slate-50 rounded-2xl p-8 md:p-12">
          <h3 class="text-2xl font-bold text-slate-900 mb-6">Ready to Transform Your Technology?</h3>
          <p class="text-slate-600 mb-6">
            Whether you're modernizing legacy systems, building new capabilities, or optimizing 
            your development process, I'm here to help.
          </p>
          <a href="/contact" class="btn-primary">
            Get in Touch
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-slate-900 text-white">
    <div class="container-tight text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        Let's Build Something Great Together
      </h2>
      <p class="text-xl text-slate-300 mb-8 max-w-2xl mx-auto">
        Every successful project starts with a conversation. Tell me about your challenges, 
        and let's explore how I can help.
      </p>
      <a href="/contact#consultation" class="btn-primary text-lg px-8 py-4">
        Schedule a Consultation
      </a>
    </div>
  </section>
</Layout>
