---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-100">
  <nav class="container-tight">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-3">
        <img src="/Logo-icon.svg" alt="Zelnot" class="h-12 w-auto" />
      </a>

      <div class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              "text-sm font-medium transition-colors",
              currentPath === link.href
                ? "text-sky-500"
                : "text-slate-600 hover:text-slate-900"
            ]}
          >
            {link.label}
          </a>
        ))}
        <a href="/contact#consultation" class="btn-primary text-sm">
          Request a Consultation
        </a>
      </div>

      <button id="mobile-menu-toggle" class="md:hidden p-2 text-slate-600">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden pb-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            "block py-2 text-sm font-medium",
            currentPath === link.href
              ? "text-sky-500"
              : "text-slate-600"
          ]}
        >
          {link.label}
        </a>
      ))}
      <a href="/contact#consultation" class="btn-primary text-sm mt-4 w-fit">
        Request a Consultation
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
