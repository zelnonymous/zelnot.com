---
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-900 text-slate-300 mt-auto px-0 py-8">
  <div class="container-tight py-12 md:py-16 px-6">
    <div class="grid md:grid-cols-3 gap-8">
      <div>
        <img src="/Logo-icon-light.svg" alt="Zelnot" class="h-16 w-auto mb-4" />
        <p class="text-sm text-slate-400">
          Technology consulting for businesses from startup to enterprise
        </p>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-4">Services</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/services#development" class="hover:text-white transition-colors">Custom Software Development</a></li>
          <li><a href="/services#integration" class="hover:text-white transition-colors">Software Integration</a></li>
          <li><a href="/services#devops" class="hover:text-white transition-colors">DevOps & CI/CD</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-4">Contact</h4>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="mailto:zelnot@zelnot.com" class="hover:text-white transition-colors">
              zelnot@zelnot.com
            </a>
          </li>
          <li>
            <a href="tel:+14125270161" class="hover:text-white transition-colors">
              (412) 527-0161
            </a>
          </li>
          <li class="text-slate-400">Pittsburgh, PA</li>
        </ul>
      </div>
    </div>

    <div class="border-t border-slate-800 mt-12 pt-8 text-sm text-slate-500 flex flex-col sm:flex-row justify-between gap-4">
      <p>&copy; {currentYear} Zelnot. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
